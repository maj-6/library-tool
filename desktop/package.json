{
  "name": "whl-library-tool",
  "productName": "Library Tool",
  "version": "0.8.0-alpha.15",
  "description": "Desktop shell for Library Tool — a World Herb Library companion (Flask sidecar + Electron)",
  "author": "Andrew James Miller",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:sidecar": "python3 -m PyInstaller --clean --noconfirm --distpath dist-sidecar --workpath build-sidecar sidecar/whl_explorer.spec",
    "pack": "electron-builder --dir",
    "dist": "npm run build:sidecar && electron-builder --win",
    "release": "npm run dist && echo Now: gh release create v%npm_package_version% release\\LibraryTool-Setup-%npm_package_version%.exe release\\latest.yml --title v%npm_package_version%"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "org.worldherblibrary.librarytool",
    "productName": "Library Tool",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "window-registry.js",
      "startup.html",
      "startup-preload.js",
      "updater.html",
      "updater-preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-sidecar/whl-explorer-sidecar",
        "to": "sidecar",
        "filter": ["**/*"]
      },
      {
        "from": "../icon.png",
        "to": "startup-assets/icon.png"
      },
      {
        "from": "../tools/whl_explorer/static/fonts/roboto-slab-var.woff2",
        "to": "startup-assets/roboto-slab-var.woff2"
      }
    ],
    "fileAssociations": [
      {
        "ext": "lib",
        "name": "Library Tool Book",
        "description": "Library Tool book archive",
        "icon": "build/lib-file.ico",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "artifactName": "LibraryTool-Setup-${version}.${ext}",
      "signtoolOptions": {
        "signingHashAlgorithms": ["sha256"],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Library Tool",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "maj-6",
      "repo": "library-tool"
    }
  }
}
