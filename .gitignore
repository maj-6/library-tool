# Open Library dumps + built indexes (huge, rebuildable via tools/build_ol_*.py)
ol_dump_*
output/ol_works*
output/ol_search*
output/ol_build*

# API caches (rebuild themselves)
output/.ol_api_cache.json*
output/.online_cache.json

# device-local UI/session state (checked books, settings incl. API keys,
# attention marks) — per-user, not version-controlled
output/client_state.json
# automatic pre-shrink snapshots of client_state + ad-hoc recovery artifacts
# (also device-local, and can hold the same checked-book data)
output/backups/
# append-only feed behind the Home tab; grows per machine, merges badly
output/activity.jsonl
# the signed-in Supabase session (user tokens) + the activity push cursor
output/auth_session.json
# device-local record of what the cloud already has (working-store sync shadow)
output/cloud_shadow.json

# downloaded scans (large binaries)
downloads/ia/*.pdf
downloads/ia/*.part

# live catalogue data: mutated by the running app and synced through the
# cloud backend, not through git (entry folders hold per-book OCR + PDF
# derivatives; whl_builds.json is the builds database; catalog.json tracks
# what's on disk; corrections + the generated report are working artifacts)
downloads/ia/catalog.json
output/whl_builds.json
output/whl_corrections.json
output/ch_library_report.xlsx
output/entries/

# the private book corpus: capture photography + per-book scan images.
# Synced through R2 (tools/corpus_sync.py), not through git; the OCR
# transcripts (books/*/transcript.txt) stay tracked — small, diffable text.
photo/
books/**/*.jpg
books/**/*.jpeg
books/**/*.png

# per-worktree launcher + its private DATA_ROOT (tools/worktree.py)
.wt/

# the website's Supabase project ref + anon key — public by design, but yours
website/assets/config.js

# python
__pycache__/
*.pyc
*.egg-info/
downloads/cache/

# Claude Code's per-machine permission grants — the approved command lines can
# quote API keys verbatim, so this must never be committed
.claude/settings.local.json
# per-checkout: each worktree binds its own port (see .claude/launch.example.json)
.claude/launch.json

# Android Studio local state: build cache, and local.properties (the SDK path;
# the file itself says not to commit it). The gradle wrapper IS tracked, so a
# fresh clone can still ./gradlew build.
android/BookCapture/.gradle/
android/BookCapture/build/
android/BookCapture/app/build/
android/BookCapture/local.properties
# ...and the per-machine corners of .idea: a 2k-line device catalogue and
# whichever device the Run button last pointed at
android/BookCapture/.idea/caches/
android/BookCapture/.idea/deploymentTargetSelector.xml

# large binaries kept local, excluded from the published repo (the corpus
# images are covered by their own block above since they left git entirely)
copyright_renewals.csv
