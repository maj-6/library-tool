# Open Library dumps + built indexes (huge, rebuildable via tools/build_ol_*.py)
ol_dump_*
output/ol_works*
output/ol_search*
output/ol_build*

# API caches (rebuild themselves)
output/.ol_api_cache.json*
output/.online_cache.json

# device-local UI/session state (checked books, settings incl. API keys,
# attention marks) — per-user, not version-controlled
output/client_state.json
# automatic pre-shrink snapshots of client_state + ad-hoc recovery artifacts
# (also device-local, and can hold the same checked-book data)
output/backups/

# downloaded scans (large binaries; downloads/ia/catalog.json IS tracked)
downloads/ia/*.pdf
downloads/ia/*.part

# python
__pycache__/
*.pyc
downloads/cache/
output/entries/**/*.pdf

# large binaries kept local, excluded from the published repo
photo/
copyright_renewals.csv
books/**/*.jpg
.claude/
