<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BookCapture">

        <!-- Home is the landing screen: the app opens on the recent-scans list,
             not the camera. -->
        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Capture, reached from Home's "New scan". keep-screen-on is a window
             flag set in MainActivity.onCreate. -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:parentActivityName=".HomeActivity"
            android:screenOrientation="portrait" />

        <!-- exported + singleTop so the OAuth redirect (a browser-launched deep
             link) re-enters this same activity via onNewIntent -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="org.whl.bookcapture" android:host="auth-callback" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title" />

        <activity
            android:name=".EntryDetailActivity"
            android:exported="false"
            android:label="@string/app_name" />
    </application>
</manifest>
