<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/whl_face_sh2" />
            <stroke android:width="1dp" android:color="@color/whl_ink_dim" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/whl_blue2" />
            <stroke android:width="1dp" android:color="@color/whl_ink" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/whl_cyan" />
            <stroke android:width="1dp" android:color="@color/whl_ink" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</selector>
