<?xml version="1.0" encoding="utf-8"?>
<!-- The square the app mark sits in at the head of the toolbar. Reads as a
     recessed tile rather than a button so it does not compete with the tabs
     beside it, but it does take a pressed state: tapping it opens the app menu. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/whl_row_checked" />
            <stroke android:width="1dp" android:color="@color/whl_face_sh2" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/whl_face_hi" />
            <stroke android:width="1dp" android:color="@color/whl_face_sh2" />
            <corners android:radius="3dp" />
        </shape>
    </item>
</selector>
