<?xml version="1.0" encoding="utf-8"?>
<!-- One collection on the Collections tab: the batch name, where that batch came
     from, and how many books have been scanned into it. Tapping selects it as
     the collection the next book lands in; the trailing icons edit/delete it. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="8dp"
    android:paddingTop="9dp"
    android:paddingBottom="9dp"
    android:background="@drawable/whl_row">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/whl_ink"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:fontFamily="monospace"
            android:textColor="@color/whl_ink_dim"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/editCollection"
        style="@style/WhlInlineIconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/collections_edit"
        app:srcCompat="@drawable/ic_edit"
        app:tint="@color/whl_ink" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/deleteCollection"
        style="@style/WhlInlineIconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/collections_delete"
        app:srcCompat="@drawable/ic_delete"
        app:tint="@color/whl_red" />
</LinearLayout>
