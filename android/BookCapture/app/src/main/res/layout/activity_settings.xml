<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whl_canvas"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:background="@drawable/whl_panel"
        android:elevation="2dp"
        app:navigationContentDescription="@string/navigate_up"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/whl_ink"
        app:title="@string/settings_title"
        app:titleTextColor="@color/whl_ink" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- account -->
        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/set_account" />
            <TextView
                android:id="@+id/accountEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textColor="@color/whl_ink" />
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/set_display_name" />
            <EditText
                android:id="@+id/displayName"
                style="@style/WhlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:inputType="textPersonName"
                android:importantForAutofill="no" />
            <Button
                android:id="@+id/signOut"
                style="@style/WhlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="12sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/set_sign_out" />
        </LinearLayout>

        <!-- device -->
        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/device_name" />
            <EditText
                android:id="@+id/device"
                style="@style/WhlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:inputType="text"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- camera -->
        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/set_camera" />
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/set_capture_profile" />
            <RadioGroup
                android:id="@+id/cameraProfileGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <RadioButton
                    android:id="@+id/cameraProfileFast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:text="@string/set_camera_fast"
                    android:textColor="@color/whl_ink" />
                <RadioButton
                    android:id="@+id/cameraProfileDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:text="@string/set_camera_detail"
                    android:textColor="@color/whl_ink" />
            </RadioGroup>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/continuousLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/set_continuous_light"
                android:textColor="@color/whl_ink" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/sharpenPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="48dp"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textColor="@color/whl_ink"
                android:text="@string/set_sharpen" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="@color/whl_ink_dim"
                android:text="@string/set_sharpen_note" />
            <Button
                android:id="@+id/resetCamera"
                style="@style/WhlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/set_camera_reset"
                android:textSize="12sp" />
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/set_camera_diagnostics" />
            <TextView
                android:id="@+id/cameraDiagnostics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="@color/whl_ink_dim" />
        </LinearLayout>

        <!-- voice is optional and downloads its model only after opt-in -->
        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/set_voice" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/voiceControl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/set_voice_enable"
                android:textColor="@color/whl_ink" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="@color/whl_ink_dim"
                android:text="@string/set_voice_note" />
        </LinearLayout>

        <!-- transport / LAN pairing -->
        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/set_transport" />
            <RadioGroup
                android:id="@+id/transportGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/transportCloud"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:fontFamily="monospace"
                    android:textSize="12sp" android:textColor="@color/whl_ink"
                    android:text="@string/transport_cloud" />
                <RadioButton android:id="@+id/transportLan"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:fontFamily="monospace"
                    android:textSize="12sp" android:textColor="@color/whl_ink"
                    android:text="@string/transport_lan" />
                <RadioButton android:id="@+id/transportAuto"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:fontFamily="monospace"
                    android:textSize="12sp" android:textColor="@color/whl_ink"
                    android:text="@string/transport_auto" />
            </RadioGroup>
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/lan_host" />
            <EditText android:id="@+id/lanHost"
                style="@style/WhlInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:inputType="textNoSuggestions"
                android:importantForAutofill="no"
                android:hint="@string/lan_host_hint" />
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/lan_token" />
            <EditText android:id="@+id/lanToken"
                style="@style/WhlInput"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:inputType="textPassword"
                android:importantForAutofill="no" />
            <Button android:id="@+id/lanTest"
                style="@style/WhlButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="12sp"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:text="@string/lan_test" />
            <TextView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace" android:textSize="11sp"
                android:textColor="@color/whl_ink_dim"
                android:text="@string/lan_note" />
        </LinearLayout>

        <!-- API keys, synced to the account -->
        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/set_api_keys" />
            <TextView
                android:id="@+id/apiKeysNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="@color/whl_ink_dim"
                android:text="@string/set_api_keys_note" />
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/set_mistral" />
            <EditText
                android:id="@+id/mistralKey"
                style="@style/WhlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:inputType="textPassword"
                android:importantForAutofill="no" />
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/set_deepseek" />
            <EditText
                android:id="@+id/deepseekKey"
                style="@style/WhlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:inputType="textPassword"
                android:importantForAutofill="no" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <Button
                android:id="@+id/save"
                style="@style/WhlButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:textSize="13sp"
                android:text="@string/save" />
            <Button
                android:id="@+id/test"
                style="@style/WhlButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:text="@string/test_connection" />
        </LinearLayout>

        <TextView
            android:id="@+id/msg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/whl_ink_light" />
    </LinearLayout>
    </ScrollView>
</LinearLayout>
