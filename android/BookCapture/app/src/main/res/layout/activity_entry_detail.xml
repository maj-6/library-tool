<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whl_canvas"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:background="@drawable/whl_panel"
        android:elevation="2dp"
        app:navigationContentDescription="@string/navigate_up"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/whl_ink"
        app:title="@string/detail_title"
        app:titleTextColor="@color/whl_ink" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/whl_ink" />

            <TextView
                android:id="@+id/subline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="@color/whl_ink_dim" />

            <TextView
                android:id="@+id/stateLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:textColor="@color/whl_ink_dim" />

            <TextView
                android:id="@+id/ownershipNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="@color/whl_amber"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/claimCloud"
                style="@style/WhlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="@string/detail_claim_cloud"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- extracted fields, one mono row each, added in code -->
            <LinearLayout
                android:id="@+id/fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />
        </LinearLayout>

        <Button
            android:id="@+id/deepseekInstructions"
            style="@style/WhlButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_gravity="end"
            android:contentDescription="@string/detail_deepseek_action_description"
            android:drawableStart="@drawable/ic_sparkles"
            android:drawablePadding="8dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/detail_deepseek_action"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/reprocessAvailability"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="@color/whl_ink_dim"
            android:visibility="gone" />

        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/detail_photos" />
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">
                <LinearLayout
                    android:id="@+id/photos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout style="@style/WhlPanelSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView style="@style/WhlLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/detail_ocr" />
            <TextView
                android:id="@+id/ocrText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textIsSelectable="true"
                android:textColor="@color/whl_ink" />
        </LinearLayout>

        <Button
            android:id="@+id/discard"
            style="@style/WhlButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_gravity="end"
            android:textSize="12sp"
            android:textColor="@color/whl_button_text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:visibility="gone"
            android:text="@string/detail_discard" />
    </LinearLayout>
    </ScrollView>
</LinearLayout>
