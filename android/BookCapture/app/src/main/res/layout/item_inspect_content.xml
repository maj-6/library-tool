<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/whl_row"
    android:gravity="center_vertical"
    android:minHeight="72dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="7dp"
    android:paddingEnd="4dp"
    android:paddingBottom="7dp">

    <ImageView
        android:id="@+id/inspectThumb"
        android:layout_width="42dp"
        android:layout_height="56dp"
        android:layout_marginEnd="10dp"
        android:background="@color/whl_face_sh"
        android:contentDescription="@string/detail_photos"
        android:foreground="@drawable/whl_thumbnail_frame"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_app_mark" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/inspectTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/whl_ink"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/inspectSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="2"
            android:textColor="@color/whl_ink_dim"
            android:textSize="11sp" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/inspectOpen"
        style="@style/WhlInlineIconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/home_open_details"
        app:srcCompat="@drawable/ic_chevron_right" />
</LinearLayout>
