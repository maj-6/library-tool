<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/detail_deepseek_help"
            android:textColor="@color/whl_ink_dim"
            android:textIsSelectable="true"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/customInstructions"
            style="@style/WhlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top|start"
            android:hint="@string/detail_deepseek_hint"
            android:importantForAutofill="no"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLength="4000"
            android:minHeight="120dp" />

        <TextView
            android:id="@+id/reprocessState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:textColor="@color/whl_ink_dim"
            android:textIsSelectable="true"
            android:textSize="11sp" />

        <Button
            android:id="@+id/resubmit"
            style="@style/WhlButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:contentDescription="@string/detail_resubmit_description"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/detail_resubmit"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
