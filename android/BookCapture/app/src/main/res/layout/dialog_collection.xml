<?xml version="1.0" encoding="utf-8"?>
<!-- Add or edit a collection: what to call the batch, and where it came from.
     The origin becomes the default "From" on every book scanned into it. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <TextView
            style="@style/WhlLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/collections_field_name" />

        <EditText
            android:id="@+id/collectionName"
            style="@style/WhlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:importantForAutofill="no"
            android:hint="@string/collections_hint_name" />

        <TextView
            style="@style/WhlLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/collections_field_from" />

        <EditText
            android:id="@+id/collectionFrom"
            style="@style/WhlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:importantForAutofill="no"
            android:hint="@string/collections_hint_from" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="@color/whl_ink_dim"
            android:text="@string/collections_from_help" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/cancelCollectionEdit"
                style="@style/WhlIconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/collections_cancel_edit_description"
                app:srcCompat="@drawable/ic_cancel"
                app:tint="@color/whl_icon_button_tint" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/saveCollectionEdit"
                style="@style/WhlIconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/collections_save_edit_description"
                app:srcCompat="@drawable/ic_done"
                app:tint="@color/whl_icon_button_tint" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
