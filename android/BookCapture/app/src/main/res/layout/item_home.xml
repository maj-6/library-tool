<?xml version="1.0" encoding="utf-8"?>
<!-- One recent-scan card on the Home page: a page thumbnail, the extracted
     book record (or progress), and the upload/import status. Tapping opens the
     full detail (all photos, OCR text, every field). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="9dp"
    android:paddingBottom="9dp"
    android:background="?android:attr/selectableItemBackground">

    <CheckBox
        android:id="@+id/selected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="7dp"
        android:buttonTint="@color/whl_cyan"
        android:visibility="gone"
        android:contentDescription="@string/home_select_scan" />

    <ImageView
        android:id="@+id/thumb"
        android:layout_width="46dp"
        android:layout_height="60dp"
        android:layout_marginEnd="11dp"
        android:scaleType="centerCrop"
        android:background="@color/whl_face_sh"
        android:contentDescription="@string/detail_photos" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/whl_ink"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:fontFamily="monospace"
            android:textColor="@color/whl_ink_dim"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <View
        android:id="@+id/marker"
        android:layout_width="7dp"
        android:layout_height="7dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="6dp"
        android:background="@color/whl_face_sh2" />

    <TextView
        android:id="@+id/state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:textAllCaps="true"
        android:textColor="@color/whl_ink_dim" />
</LinearLayout>
