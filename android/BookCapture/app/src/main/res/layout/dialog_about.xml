<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Exactly the height of the adjacent title/version block. -->
        <ImageView
            android:id="@+id/aboutIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/whl_icon_plate"
            android:contentDescription="@string/about_icon_description"
            android:padding="1dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_app_mark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/aboutTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_slab"
                android:textColor="@color/whl_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/aboutVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/roboto_slab"
                android:textColor="@color/whl_ink_dim"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/aboutDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/roboto_slab"
        android:linksClickable="true"
        android:textColor="@color/whl_ink"
        android:textColorLink="@color/whl_cyan"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/roboto_slab"
        android:text="@string/about_changelog_title"
        android:textColor="@color/whl_ink"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/aboutChangelogScroll"
        android:layout_width="match_parent"
        android:layout_height="184dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/whl_input"
        android:fadeScrollbars="false"
        android:fillViewport="true"
        android:scrollbarStyle="insideInset">

        <TextView
            android:id="@+id/aboutChangelog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_slab"
            android:padding="10dp"
            android:textColor="@color/whl_ink_dim"
            android:textIsSelectable="true"
            android:textSize="11sp" />
    </ScrollView>
</LinearLayout>
