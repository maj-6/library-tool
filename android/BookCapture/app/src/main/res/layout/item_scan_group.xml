<?xml version="1.0" encoding="utf-8"?>
<!-- Collapsible collection heading in the Scans list. The whole 48 dp row is
     the control; its chevron is decorative and the runtime description names
     the expand/collapse action for accessibility. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="48dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="12dp"
    android:background="@drawable/whl_scan_group_header"
    android:clickable="true"
    android:focusable="true"
    android:descendantFocusability="blocksDescendants">

    <ImageView
        android:id="@+id/groupChevron"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="6dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_chevron_right" />

    <TextView
        android:id="@+id/groupName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/whl_ink"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/groupCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="monospace"
        android:textColor="@color/whl_ink_dim"
        android:textSize="11sp" />
</LinearLayout>
