<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whl_canvas">

    <!-- masthead: wordmark + settings, one face panel like the desktop toolbar -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/whl_panel"
        android:paddingStart="14dp"
        android:paddingEnd="6dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_fg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/roboto_slab"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/whl_ink"
            android:text="@string/home_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelect"
            style="@style/WhlToolbarAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:text="@string/home_select" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/WhlToolbarAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/open_settings"
            android:textSize="18sp"
            android:text="@string/gear" />
    </LinearLayout>

    <!-- Scans / Collections. A segmented row rather than a TabLayout so the
         chrome keeps the same flat panel language as the rest of the app. -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/whl_panel"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabScans"
            style="@style/WhlToolbarAction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:text="@string/home_tab_scans" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabCollections"
            style="@style/WhlToolbarAction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:text="@string/home_tab_collections" />
    </LinearLayout>

    <TextView
        android:id="@+id/configWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="@color/whl_ink_light"
        android:background="@color/whl_red"
        android:visibility="gone"
        android:text="@string/not_signed_in"
        app:layout_constraintTop_toBottomOf="@id/tabBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/selectionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="8dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:background="@drawable/whl_panel"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/configWarning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/selectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/whl_ink" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteSelected"
            style="@style/WhlToolbarAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/whl_red"
            android:text="@string/home_delete_selected" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelSelection"
            style="@style/WhlToolbarAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:text="@string/home_cancel_select" />
    </LinearLayout>

    <!-- which collection the next book lands in; tap to go and change it -->
    <TextView
        android:id="@+id/collectionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:background="@drawable/whl_row"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="@color/whl_ink_dim"
        app:layout_constraintTop_toBottomOf="@id/selectionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- one pane per tab; only the active one is visible -->
    <ScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/collectionBar"
        app:layout_constraintBottom_toTopOf="@id/bottomAction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/homeList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="2dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/collectionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="2dp"
                android:paddingBottom="8dp" />
        </LinearLayout>
    </ScrollView>

    <!-- One slot, one button per tab. They share a container so the list above
         keeps a stable bottom edge: a GONE sibling in a ConstraintLayout
         collapses to a point at the parent's bottom, which would let the list
         scroll underneath whichever button is currently showing. -->
    <FrameLayout
        android:id="@+id/bottomAction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- the way into capture; the app no longer opens straight onto the camera -->
        <Button
            android:id="@+id/newScan"
            style="@style/WhlButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_camera_new"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:textSize="15sp"
            android:text="@string/home_new_scan" />

        <Button
            android:id="@+id/newCollection"
            style="@style/WhlButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="15sp"
            android:visibility="gone"
            android:text="@string/collections_new" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
