<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whl_canvas">

    <!-- masthead: the app mark, then the tabs, on one face panel like the
         desktop toolbar. The mark is the menu — Settings/About/updates hang off
         it, so the chrome carries no separate gear. -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/whl_panel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/appMenu"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="1dp"
            android:background="@drawable/whl_icon_plate"
            android:contentDescription="@string/app_menu"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_app_mark" />

        <!-- The mark is a separate menu plate, not a third tab. This quiet
             rule keeps it visually distinct without putting a border around
             the botanical-green square. -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/whl_face_sh2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabScans"
            style="@style/WhlToolbarAction"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:fontFamily="@font/roboto_slab"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:text="@string/home_tab_scans"
            app:icon="@drawable/ic_scans"
            app:iconGravity="textStart"
            app:iconPadding="7dp"
            app:iconSize="20dp"
            app:iconTint="@color/whl_ink" />

        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="@color/whl_face_sh2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabCollections"
            style="@style/WhlToolbarAction"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:fontFamily="@font/roboto_slab"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:text="@string/home_tab_collections"
            app:icon="@drawable/ic_collections"
            app:iconGravity="textStart"
            app:iconPadding="7dp"
            app:iconSize="20dp"
            app:iconTint="@color/whl_ink" />
    </LinearLayout>

    <TextView
        android:id="@+id/configWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="@color/whl_ink_light"
        android:background="@color/whl_red"
        android:visibility="gone"
        android:text="@string/not_signed_in"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- which collection the next book lands in; tap to go and change it -->
    <TextView
        android:id="@+id/collectionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:background="@drawable/whl_row"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="@color/whl_ink_dim"
        app:layout_constraintTop_toBottomOf="@id/configWarning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- one pane per tab; only the active one is visible -->
    <ScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/collectionBar"
        app:layout_constraintBottom_toTopOf="@id/bottomAction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/homeList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="2dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/collectionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="2dp"
                android:paddingBottom="8dp" />
        </LinearLayout>
    </ScrollView>

    <!-- One slot, one button per tab. They share a container so the list above
         keeps a stable bottom edge: a GONE sibling in a ConstraintLayout
         collapses to a point at the parent's bottom, which would let the list
         scroll underneath whichever button is currently showing. -->
    <FrameLayout
        android:id="@+id/bottomAction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- the way into capture; the app no longer opens straight onto the camera -->
        <LinearLayout
            android:id="@+id/scanActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/newScan"
                style="@style/WhlButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:fontFamily="@font/roboto_slab"
                android:gravity="center"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:text="@string/home_new_scan"
                app:icon="@drawable/ic_camera_new"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="26dp"
                app:iconTint="@color/whl_button_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/syncCaptures"
                style="@style/WhlButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/roboto_slab"
                android:gravity="center"
                android:accessibilityLiveRegion="polite"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:text="@string/home_sync_captures"
                app:icon="@drawable/ic_sync_upload"
                app:iconGravity="textStart"
                app:iconPadding="7dp"
                app:iconSize="24dp"
                app:iconTint="@color/whl_button_text" />
        </LinearLayout>

        <Button
            android:id="@+id/newCollection"
            style="@style/WhlButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_slab"
            android:gravity="center"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:visibility="gone"
            android:text="@string/collections_new" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
