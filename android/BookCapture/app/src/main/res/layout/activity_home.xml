<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whl_canvas">

    <!-- masthead: wordmark + settings, one face panel like the desktop toolbar -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/whl_panel"
        android:paddingStart="14dp"
        android:paddingEnd="6dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/whl_ink"
                android:text="@string/home_title" />

            <TextView
                android:id="@+id/homeSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="@color/whl_ink_dim"
                android:text="@string/home_subtitle" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="18sp"
            android:textColor="@color/whl_ink"
            android:padding="8dp"
            android:text="@string/gear" />
    </LinearLayout>

    <TextView
        android:id="@+id/configWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="@color/whl_ink_light"
        android:background="@color/whl_red"
        android:visibility="gone"
        android:text="@string/not_signed_in"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- the recent-scans list -->
    <ScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/configWarning"
        app:layout_constraintBottom_toTopOf="@id/newScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/homeList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="2dp"
            android:paddingBottom="8dp" />
    </ScrollView>

    <!-- the way into capture; the app no longer opens straight onto the camera -->
    <Button
        android:id="@+id/newScan"
        style="@style/WhlButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:textSize="15sp"
        android:text="@string/home_new_scan"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
