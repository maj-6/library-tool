<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:background="@drawable/whl_panel"
    android:gravity="center_vertical"
    android:minHeight="92dp"
    android:orientation="horizontal"
    android:padding="8dp">

    <ImageView
        android:id="@+id/inspectThumb"
        android:layout_width="48dp"
        android:layout_height="68dp"
        android:layout_marginEnd="8dp"
        android:background="@color/whl_face_sh"
        android:contentDescription="@string/detail_photos"
        android:foreground="@drawable/whl_thumbnail_frame"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_app_mark" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/inspectTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/whl_ink"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/inspectSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="2"
            android:textColor="@color/whl_ink_dim"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
