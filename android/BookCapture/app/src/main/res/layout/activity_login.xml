<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whl_canvas">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:orientation="vertical"
        android:background="@drawable/whl_panel"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/whl_ink"
            android:text="@string/app_wordmark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            style="@style/WhlLabel"
            android:text="@string/login_sub" />

        <TextView style="@style/WhlLabel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/login_email" />
        <EditText
            android:id="@+id/email"
            style="@style/WhlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="12dp"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress"
            android:importantForAutofill="yes" />

        <TextView style="@style/WhlLabel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/login_password" />
        <EditText
            android:id="@+id/password"
            style="@style/WhlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="16dp"
            android:inputType="textPassword"
            android:autofillHints="password"
            android:importantForAutofill="yes" />

        <Button
            android:id="@+id/signIn"
            style="@style/WhlButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:text="@string/login_sign_in" />

        <Button
            android:id="@+id/register"
            style="@style/WhlButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:text="@string/login_register" />

        <TextView
            android:id="@+id/msg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/whl_red" />
    </LinearLayout>
</FrameLayout>
