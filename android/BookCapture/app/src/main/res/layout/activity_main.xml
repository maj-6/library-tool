<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whl_canvas">

    <!-- chrome: title row + status line, one face panel like the desktop toolbar -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/whl_panel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="4dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_launcher_fg" />

            <TextView
                android:id="@+id/entryState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/whl_ink"
                android:text="@string/entry_idle" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
        </LinearLayout>

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="@color/whl_ink_dim" />
    </LinearLayout>

    <androidx.camera.view.PreviewView
        android:id="@+id/preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:scaleType="fillCenter"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        app:layout_constraintBottom_toTopOf="@id/thumbs_scroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <org.whl.bookcapture.PageMarginOverlayView
        android:id="@+id/pageMarginOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="@id/preview"
        app:layout_constraintBottom_toBottomOf="@id/preview"
        app:layout_constraintStart_toStartOf="@id/preview"
        app:layout_constraintEnd_toEndOf="@id/preview" />

    <!-- shutter flash: a white overlay pulsed on capture, invisible at rest -->
    <View
        android:id="@+id/shutterFlash"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FFFFFF"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="@id/preview"
        app:layout_constraintBottom_toBottomOf="@id/preview"
        app:layout_constraintStart_toStartOf="@id/preview"
        app:layout_constraintEnd_toEndOf="@id/preview" />

    <!-- Live voice-note structure floats over the preview only while a note is
         active. It is intentionally shallow and translucent so page framing
         remains visible underneath it. -->
    <LinearLayout
        android:id="@+id/noteOverlay"
        android:layout_width="0dp"
        android:layout_height="156dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="68dp"
        android:background="@drawable/whl_note_overlay"
        android:elevation="5dp"
        android:orientation="vertical"
        android:padding="6dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/preview"
        app:layout_constraintStart_toStartOf="@id/preview"
        app:layout_constraintTop_toTopOf="@id/preview">

        <TextView
            android:id="@+id/noteStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans"
            android:text="@string/capture_note_connecting"
            android:textColor="@color/whl_green"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/noteUnclassified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:maxLines="2"
            android:textColor="@color/whl_ink_dim"
            android:textSize="10sp"
            android:visibility="gone" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:fadeScrollbars="false"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/noteRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnNote"
        style="@style/WhlIconButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="@string/capture_note_start"
        android:elevation="7dp"
        app:layout_constraintEnd_toEndOf="@id/preview"
        app:layout_constraintTop_toTopOf="@id/preview"
        app:srcCompat="@drawable/ic_note"
        app:tint="@color/whl_icon_button_tint" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnCameraSettings"
        style="@style/WhlIconButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="@string/camera_settings_open"
        android:elevation="7dp"
        app:layout_constraintEnd_toEndOf="@id/preview"
        app:layout_constraintTop_toBottomOf="@id/btnNote"
        app:srcCompat="@drawable/ic_camera_settings"
        app:tint="@color/whl_icon_button_tint" />

    <!-- The plate never rotates or changes sides. Switching page orientation
         replaces only the glyph and CameraX target rotation. -->
    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnCaptureOrientation"
        style="@style/WhlIconButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="@string/camera_orientation_portrait"
        android:elevation="7dp"
        app:layout_constraintEnd_toEndOf="@id/preview"
        app:layout_constraintTop_toBottomOf="@id/btnCameraSettings"
        app:srcCompat="@drawable/ic_capture_portrait"
        app:tint="@color/whl_icon_button_tint" />

    <TextView
        android:id="@+id/configWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="@color/whl_ink_light"
        android:background="@color/whl_red"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/thumbs_scroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <HorizontalScrollView
        android:id="@+id/thumbs_scroll"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:background="@color/whl_canvas_line"
        android:padding="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/lastBookPreview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/thumbs"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- The newest sealed/submitted book remains here while the next book is
         open. It changes only when that next capture is sent for processing. -->
    <LinearLayout
        android:id="@+id/lastBookPreview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="108dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:background="@drawable/whl_panel"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/lastBookThumb"
            android:layout_width="66dp"
            android:layout_height="86dp"
            android:layout_marginEnd="10dp"
            android:background="@color/whl_face_sh"
            android:contentDescription="@string/capture_last_book_empty"
            android:foreground="@drawable/whl_thumbnail_frame"
            android:padding="1dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/ic_launcher_safe_fg" />

        <LinearLayout
            android:id="@+id/lastBookPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_slab"
                android:text="@string/capture_last_book_label"
                android:textColor="@color/whl_ink_dim"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/lastBookTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:fontFamily="@font/roboto_slab"
                android:maxLines="2"
                android:text="@string/capture_last_book_empty"
                android:textColor="@color/whl_ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lastBookAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:fontFamily="@font/roboto_slab"
                android:maxLines="1"
                android:text="@string/capture_last_book_author_empty"
                android:textColor="@color/whl_ink_dim"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/lastBookYear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/roboto_slab"
                android:maxLines="1"
                android:text="@string/capture_last_book_year_empty"
                android:textColor="@color/whl_ink_dim"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/lastBookExtrasGroup"
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/lastBookExtras"
                style="@style/WhlIconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/capture_extra_fields_description_placeholder"
                app:srcCompat="@drawable/ic_extra_fields"
                app:tint="@color/whl_icon_button_tint" />

            <TextView
                android:id="@+id/lastBookExtraCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no"
                android:text="@string/capture_extra_fields_count_placeholder"
                android:textColor="@color/whl_ink_dim"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- glyph controls; labels are the abstraction, tones the confirmation -->
    <LinearLayout
        android:id="@+id/buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/whl_panel"
        android:padding="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnStart"
            style="@style/WhlIconButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/cmd_start"
            app:srcCompat="@drawable/ic_camera_new"
            app:tint="@color/whl_icon_button_tint" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPhoto"
            style="@style/WhlIconButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/cmd_photo"
            app:srcCompat="@drawable/ic_camera"
            app:tint="@color/whl_icon_button_tint" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnDone"
            style="@style/WhlIconButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/cmd_done"
            app:srcCompat="@drawable/ic_done"
            app:tint="@color/whl_icon_button_tint" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnCancel"
            style="@style/WhlIconButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:contentDescription="@string/cmd_cancel"
            app:srcCompat="@drawable/ic_cancel"
            app:tint="@color/whl_icon_button_tint" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
