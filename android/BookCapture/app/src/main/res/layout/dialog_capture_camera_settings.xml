<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <TextView
            style="@style/WhlLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/camera_settings_focus_heading" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cameraFocusLock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/camera_settings_focus_lock" />

        <TextView
            android:id="@+id/cameraFocusState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/camera_settings_focus_hint"
            android:textColor="@color/whl_ink_dim"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/cameraZoomLabel"
            style="@style/WhlLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/camera_settings_zoom_default" />

        <SeekBar
            android:id="@+id/cameraZoom"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:max="1000"
            android:contentDescription="@string/camera_settings_zoom" />

        <TextView
            android:id="@+id/cameraExposureLabel"
            style="@style/WhlLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/camera_settings_exposure_default" />

        <SeekBar
            android:id="@+id/cameraExposure"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:contentDescription="@string/camera_settings_exposure" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cameraTorch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/camera_settings_continuous_light" />

        <TextView
            style="@style/WhlLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/camera_settings_scan_heading" />

        <RadioGroup
            android:id="@+id/cameraProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/cameraProfileLow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/set_camera_low" />

            <RadioButton
                android:id="@+id/cameraProfileFast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/set_camera_fast" />

            <RadioButton
                android:id="@+id/cameraProfileDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/set_camera_detail" />
        </RadioGroup>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cameraSharpen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/set_sharpen" />
    </LinearLayout>
</ScrollView>
