<?xml version="1.0" encoding="utf-8"?>
<!-- The desktop Library Tool's Sage theme, translated to Android: a warm paper
     canvas, light panel faces, flat 1px chrome, monospace data on sans chrome,
     desaturated accents. Keep this palette in step with the desktop Sage theme.
     Layering: canvas is the base; panels sit slightly darker+bordered
     (recessed), inputs/buttons slightly brighter+bordered (raised). -->
<resources>
    <color name="whl_canvas">#FBF7EE</color>
    <color name="whl_canvas_line">#ECE4D5</color>
    <color name="whl_face">#E7E2D6</color>
    <color name="whl_face_hi">#FBF9F2</color>
    <color name="whl_face_sh">#CEC6B4</color>
    <color name="whl_face_sh2">#9C9280</color>
    <color name="whl_ink">#2B2720</color>
    <color name="whl_ink_light">#2B2720</color>
    <color name="whl_ink_dim">#6A6152</color>
    <color name="whl_cyan">#35635A</color>
    <color name="whl_green">#4A743A</color>
    <color name="whl_green_pressed">#385D2B</color>
    <color name="whl_amber">#97681A</color>
    <color name="whl_red">#A5402C</color>
    <color name="whl_blue">#55503F</color>
    <color name="whl_blue2">#6F6853</color>
    <color name="whl_row_checked">#DDE7D5</color>
    <color name="whl_current_blue">#DCEEF4</color>
    <color name="whl_current_blue_pressed">#C9E2EB</color>
    <color name="whl_thumbnail_border">#616661</color>
    <color name="whl_button_text">#FBF9F2</color>
    <color name="ic_launcher_bg">#4A743A</color>

    <!-- Sage is a light paper palette: default widget text goes
         dark, and the status/nav bars carry dark icons over the light canvas. -->
    <style name="Theme.BookCapture.Base" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/whl_cyan</item>
        <!-- Roboto Slab is the interface font; the mono data cells override it -->
        <item name="android:fontFamily">@font/roboto_slab</item>
        <item name="fontFamily">@font/roboto_slab</item>
        <item name="android:textColorPrimary">@color/whl_ink</item>
        <item name="android:textColorSecondary">@color/whl_ink_dim</item>
        <item name="android:statusBarColor">@color/whl_canvas</item>
        <item name="android:navigationBarColor">@color/whl_canvas</item>
        <item name="android:windowBackground">@color/whl_canvas</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.BookCapture" parent="Theme.BookCapture.Base" />

    <!-- flat glyph button: face plate, 1px strong border, ink glyph. The face
         plate press-state comes from the selector; a foreground ripple adds the
         quick tactile confirm on top (the plate alone read as "dead"). -->
    <style name="WhlButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:background">@drawable/whl_button</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:textColor">@color/whl_button_text</item>
        <item name="android:fontFamily">@font/roboto_slab</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">20sp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="WhlIconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@drawable/whl_button</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:padding">13dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Quiet icon action used inside a row. It keeps a full touch target and
         ripple without giving every edit/delete glyph a second bordered tile. -->
    <style name="WhlInlineIconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Text actions in app chrome still need a real button role and a 48dp
         target for switch access, TalkBack, and imprecise touch. -->
    <style name="WhlToolbarAction" parent="Widget.Material3.Button.TextButton">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:fontFamily">@font/roboto_slab</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/whl_ink</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <!-- mono field label / small chrome text -->
    <style name="WhlLabel">
        <item name="android:fontFamily">@font/roboto_slab</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/whl_ink_dim</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- a settings/detail card: face panel, padded, spaced from the last -->
    <style name="WhlPanelSection">
        <item name="android:background">@drawable/whl_panel</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <style name="WhlInput">
        <item name="android:background">@drawable/whl_input</item>
        <item name="android:textColor">@color/whl_ink</item>
        <item name="android:textColorHint">@color/whl_ink_dim</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">10dp</item>
    </style>
</resources>
