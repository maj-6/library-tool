<?xml version="1.0" encoding="utf-8"?>
<!-- The desktop Library Tool's CAD language, translated: light panel faces
     over the dark drafting canvas, flat 1px chrome, monospace data on sans
     chrome, desaturated accents. Palette = style.css :root. -->
<resources>
    <color name="whl_canvas">#1C1F24</color>
    <color name="whl_canvas_line">#2B2F36</color>
    <color name="whl_face">#E7E9EC</color>
    <color name="whl_face_hi">#FFFFFF</color>
    <color name="whl_face_sh">#CFD3D9</color>
    <color name="whl_face_sh2">#9AA1AA</color>
    <color name="whl_ink">#23272E</color>
    <color name="whl_ink_light">#D9DCE1</color>
    <color name="whl_ink_dim">#6B7280</color>
    <color name="whl_cyan">#00B7C3</color>
    <color name="whl_green">#23B039</color>
    <color name="whl_amber">#D8A000</color>
    <color name="whl_red">#C0392B</color>
    <color name="whl_blue">#33587E</color>
    <color name="ic_launcher_bg">#F2F1EA</color>

    <style name="Theme.BookCapture" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/whl_cyan</item>
        <item name="android:statusBarColor">@color/whl_canvas</item>
        <item name="android:navigationBarColor">@color/whl_canvas</item>
        <item name="android:windowBackground">@color/whl_canvas</item>
    </style>

    <!-- flat glyph button: face plate, 1px strong border, ink glyph -->
    <style name="WhlButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:background">@drawable/whl_button</item>
        <item name="android:textColor">@color/whl_ink</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">20sp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- mono field label / small chrome text -->
    <style name="WhlLabel">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/whl_ink_dim</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- a settings/detail card: face panel, padded, spaced from the last -->
    <style name="WhlPanelSection">
        <item name="android:background">@drawable/whl_panel</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <style name="WhlInput">
        <item name="android:background">@drawable/whl_input</item>
        <item name="android:textColor">@color/whl_ink</item>
        <item name="android:textColorHint">@color/whl_ink_dim</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">10dp</item>
    </style>
</resources>
