<?xml version="1.0" encoding="utf-8"?>
<!--
  Preferences contain the user's Supabase session and account-owned API keys.
  The project key is public and the service_role key is never stored here.
  allowBackup="false" already keeps the private values out of Android Auto
  Backup; this also keeps them out of device-to-device transfer.
-->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="sharedpref" path="bookcapture.xml" />
  </cloud-backup>
  <device-transfer>
    <exclude domain="sharedpref" path="bookcapture.xml" />
  </device-transfer>
</data-extraction-rules>
