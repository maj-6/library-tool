SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=replace-with-a-dedicated-sb_secret-key
SOURCE_BUCKET=captures
DERIVATIVE_BUCKET=capture-derivatives
CURVATURE_BACKEND=page-dewarp
MAX_SOURCE_BYTES=33554432
MAX_ATTEMPTS=4
# Keep this above the platform task timeout (the documented Cloud Run job uses 30m).
LEASE_SECONDS=2100
PROCESSOR_VERSION=0.1.0

# Needed only when deploying the optional HTTP drain API. Cloud Run Jobs do
# not expose an HTTP endpoint and do not use this value.
IMAGE_PROCESSOR_ADMIN_TOKEN=replace-with-at-least-32-random-characters
